<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TEMPLATE OWL (CORRIGÉ ODOO 19) -->
    <templates>

        <t t-name="test_management_dashboard_template">

            <div class="o_test_dashboard p-3">

                <!-- Titre -->
                <div class="d-flex align-items-center mb-4">
                    <i class="fa fa-tachometer fa-2x text-primary me-3"/>
                    <h2 class="mb-0">Dashboard QA — Test Management</h2>
                </div>

                <!-- KPI -->
                <div class="row g-3 mb-4" id="kpi_cards">

                    <div class="col-12 col-md-3">
                        <div class="card border-0 shadow-sm h-100 text-center">
                            <div class="card-body">
                                <i class="fa fa-check-circle fa-2x text-success mb-2"/>
                                <h6 class="text-muted text-uppercase small">Taux de Réussite</h6>
                                <h2 class="fw-bold text-success" id="kpi_pass_rate">—</h2>
                                <small class="text-muted" id="kpi_runs_total">0 runs au total</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-3">
                        <div class="card border-0 shadow-sm h-100 text-center">
                            <div class="card-body">
                                <i class="fa fa-bug fa-2x text-danger mb-2"/>
                                <h6 class="text-muted text-uppercase small">Bugs Ouverts</h6>
                                <h2 class="fw-bold text-danger" id="kpi_bugs_open">—</h2>
                                <small class="text-muted" id="kpi_bugs_high">dont — critiques</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-3">
                        <div class="card border-0 shadow-sm h-100 text-center">
                            <div class="card-body">
                                <i class="fa fa-spinner fa-2x text-warning mb-2"/>
                                <h6 class="text-muted text-uppercase small">Runs en Cours</h6>
                                <h2 class="fw-bold text-warning" id="kpi_runs_running">—</h2>
                                <small class="text-muted">actifs maintenant</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-3">
                        <div class="card border-0 shadow-sm h-100 text-center">
                            <div class="card-body">
                                <i class="fa fa-list-alt fa-2x text-info mb-2"/>
                                <h6 class="text-muted text-uppercase small">Cas de Test</h6>
                                <h2 class="fw-bold text-info" id="kpi_cases_total">—</h2>
                                <small class="text-muted" id="kpi_cases_done">— exécutés</small>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Graphiques -->
                <div class="row g-3 mb-4">

                    <div class="col-12 col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white fw-bold">
                                <i class="fa fa-pie-chart text-primary me-2"/>Résultats des Runs
                            </div>
                            <div class="card-body d-flex justify-content-center align-items-center">
                                <canvas id="chart_runs" style="max-height:220px;"/>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white fw-bold">
                                <i class="fa fa-exclamation-triangle text-danger me-2"/>Bugs par Sévérité
                            </div>
                            <div class="card-body d-flex justify-content-center align-items-center">
                                <canvas id="chart_bugs" style="max-height:220px;"/>
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Bas -->
                <div class="row g-3">

                    <div class="col-12 col-md-8">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white fw-bold">
                                <i class="fa fa-line-chart text-success me-2"/>Activité (7 derniers jours)
                            </div>
                            <div class="card-body">
                                <canvas id="chart_activity" style="max-height:200px;"/>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white fw-bold">
                                <i class="fa fa-folder-open text-warning me-2"/>Top Projets (bugs)
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Projet</th>
                                            <th class="text-end">Bugs</th>
                                        </tr>
                                    </thead>
                                    <tbody id="top_projects_body">
                                        <tr>
                                            <td colspan="2" class="text-center text-muted py-3">
                                                Chargement…
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </t>

    </templates>

</odoo>