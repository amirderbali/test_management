<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue Liste : Pour voir vos serveurs configurés -->
    <record id="view_jenkins_config_tree" model="ir.ui.view">
        <field name="name">jenkins.config.tree</field>
        <field name="model">jenkins.config</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <field name="name"/>
                <field name="jenkins_url"/>
                <field name="jenkins_user"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Vue Formulaire : L'interface pour configurer le serveur -->
    <record id="view_jenkins_config_form" model="ir.ui.view">
        <field name="name">jenkins.config.form</field>
        <field name="model">jenkins.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Bouton lié à la méthode test_connection de votre fichier jenkins_config.py -->
                    <button name="test_connection" type="object" string="Tester la connexion" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Ex: Jenkins Production"/></h1>
                    </div>
                    <group>
                        <group string="🌐 Serveur">
                            <field name="jenkins_url" placeholder="http://192.168.1.100:8080"/>
                            <field name="active"/>
                        </group>
                        <group string="🔐 Authentification">
                            <field name="jenkins_user"/>
                            <field name="jenkins_token" password="True"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/> 
                        Pour obtenir votre <b>Token API</b> : Allez dans Jenkins > Votre Profil > Configurer > API Token.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action pour ouvrir la configuration -->
    <record id="action_jenkins_config" model="ir.actions.act_window">
        <field name="name">Configuration Jenkins</field>
        <field name="res_model">jenkins.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configurez votre premier serveur Jenkins.
            </p>
        </field>
    </record>

    <!-- Menu : Vous pouvez le placer dans les paramètres de votre module -->
    <menuitem id="menu_jenkins_config_root" 
              name="Configuration Jenkins" 
              parent="project.menu_project_config" 
              action="action_jenkins_config" 
              sequence="100"/>

</odoo>