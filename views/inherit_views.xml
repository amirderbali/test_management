<odoo>
    <record id="view_project_tree_inherit_delete" model="ir.ui.view">
        <field name="name">project.project.list.inherit.delete</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="action">delete</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_task_form_inherit_test_management" model="ir.ui.view">
        <field name="name">project.task.form.inherit.test.management</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_test_management" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-flask">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Tests</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>