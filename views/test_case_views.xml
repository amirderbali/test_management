<odoo>

    <!-- Tree View -->
    <record id="view_test_case_tree" model="ir.ui.view">
        <field name="name">test.case.tree</field>
        <field name="model">test.case</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="project_id"/>
                <field name="tache_id"/>
                <field name="user_id"/>
                <field name="state"/>

            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_test_case_form" model="ir.ui.view">
        <field name="name">test.case.form</field>
        <field name="model">test.case</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Boutons simplifiés pour Odoo 17 -->
                    <button name="action_approve" type="object"
                            string="Approuver"
                            />
                    <button name="action_start" type="object"
                            string="Démarrer"
                            class="btn-primary"/>
                    <button name="action_done" type="object"
                            string="Terminer"
                            class="btn-success"/>
                    <button name="action_reset" type="object"
                            string="Réinitialiser"
                            class="btn-secondary"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,approved,in_progress,done"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="tache_id"/>
                        <field name="user_id"/>
                        
                    </group>

                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>

                        <page string="Étapes">
                            <field name="step_ids">
                                <list editable="bottom">
                                    <field name="sequence"/>
                                    <field name="description"/>
                                    <field name="expected_result"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_test_case" model="ir.actions.act_window">
        <field name="name">Cas de Test</field>
        <field name="res_model">test.case</field>
        <field name="view_mode">list,form</field>
    </record>


</odoo>